#!/usr/bin/env bash

if [ "$#" -lt 1 ]; then
  echo "You need to specify the service name"
  echo "Choose one of 'base', 'wordpress', 'redmine', 'wagtail' or 'all'"
  exit 1
fi

compose_files=""
for arg in "$@"; do
  case "$arg" in
    base|b)
      compose_files="${compose_files} -f compose_files/docker-compose.yaml"
      ;;
    wordpress|wp)
      compose_files="${compose_files} -f compose_files/docker-compose.wordpress.yaml"
      ;;
    redmine|r)
      compose_files="${compose_files} -f compose_files/docker-compose.redmine.yaml"
      ;;
    wagtail|wt)
      compose_files="${compose_files} -f compose_files/docker-compose.wagtail.yaml"
      ;;
    all)
      compose_files="-f compose_files/docker-compose.yaml -f compose_files/docker-compose.wordpress.yaml  -f compose_files/docker-compose.redmine.yaml  -f compose_files/docker-compose.wagtail.yaml"
      ;;
    *)
      echo "Unknown service. Choose one of 'base', 'wordpress', 'redmine', 'wagtail' or 'all'"
      exit 2
  esac
done
