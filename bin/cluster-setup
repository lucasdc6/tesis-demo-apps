#!/usr/bin/env bash
# cluster-setup — gestiona el ciclo de vida del cluster Kind para la PoC de observabilidad.
#
# Uso:
#   ./cluster-setup up      Crea el cluster e instala el stack de infraestructura
#   ./cluster-setup down    Elimina el cluster y todos sus recursos
#   ./cluster-setup status  Muestra el estado actual del cluster

set -euo pipefail

CLUSTER_NAME="demo-apps"
ENVIRONMENT="${1:-default}"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../kubernetes"
echo $SCRIPT_DIR
KUBECONFIG_PATH="$SCRIPT_DIR/.kube/config"
export KUBECONFIG="$KUBECONFIG_PATH"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m'

info()    { echo -e "${BLUE}[INFO]${NC}  $*"; }
ok()      { echo -e "${GREEN}[OK]${NC}    $*"; }
warn()    { echo -e "${YELLOW}[WARN]${NC}  $*"; }
die()     { echo -e "${RED}[ERROR]${NC} $*" >&2; exit 1; }
header()  { echo -e "\n${BOLD}==> $*${NC}"; }

usage() {
  echo -e "
${BOLD}cluster-setup${NC} — gestiona el cluster Kind para la PoC de observabilidad

${BOLD}USO${NC}
  $(basename "$0") <comando>

${BOLD}COMANDOS${NC}
  up       Crea el cluster Kind e instala ingress-nginx, KEDA y el stack LGTM
  down     Elimina el cluster y todos sus recursos
  status   Muestra nodos, namespaces y pods activos

${BOLD}REQUISITOS${NC}
  kind · kubectl · helm · helmfile
"
}

# ---------------------------------------------------------------------------
# Prerequisitos
# ---------------------------------------------------------------------------

check_requirements() {
  header "Verificando herramientas requeridas"
  local missing=0
  local versions
  for cmd in kind kubectl helm helmfile; do
    if command -v "$cmd" &>/dev/null; then
      versions=$("$cmd" version --short 2>/dev/null \
                 || "$cmd" version 2>/dev/null | head -1 \
                 || echo "(versión no disponible)")
      ok "$cmd — $versions"
    else
      echo -e "${RED}[FALTA]${NC} $cmd no está instalado."
      missing=$((missing + 1))
    fi
  done

  if [ $missing -gt 0 ]; then
    echo ""
    echo "  Instalación rápida:"
    echo "  - kind:     https://kind.sigs.k8s.io/docs/user/quick-start/#installation"
    echo "  - kubectl:  https://kubernetes.io/docs/tasks/tools/"
    echo "  - helm:     https://helm.sh/docs/intro/install/"
    echo "  - helmfile: https://helmfile.readthedocs.io/en/latest/#installation"
    echo ""
    die "Instalá las herramientas faltantes y volvé a intentarlo."
  fi
}

# ---------------------------------------------------------------------------
# Cluster
# ---------------------------------------------------------------------------

cluster_exists() {
  kind get clusters 2>/dev/null | grep -q "^${CLUSTER_NAME}$"
}

create_cluster() {
  header "Creando cluster Kind '${CLUSTER_NAME}'"
  if cluster_exists; then
    warn "El cluster '${CLUSTER_NAME}' ya existe — omitiendo creación."
    return
  fi

  mkdir -p "$SCRIPT_DIR/.kube"
  kind create cluster \
    --config "$SCRIPT_DIR/config.yaml" \
    --name "$CLUSTER_NAME" \
    --kubeconfig "$KUBECONFIG_PATH"
  ok "Cluster creado. KUBECONFIG=$KUBECONFIG_PATH"
}

# ---------------------------------------------------------------------------
# Infraestructura (helmfile)
# ---------------------------------------------------------------------------

install_infra() {
  header "Instalando infraestructura con helmfile"
  cd "$SCRIPT_DIR"

  info "1/7 — gateway-api"
  helmfile --file helmfile.d/01-gateway-api.yaml -e "${ENVIRONMENT}" apply --suppress-diff

  info "Esperando que gateway-api esté listo..."
  kubectl wait --namespace nginx-gateway \
    --for=condition=ready pod \
    --selector=gateway.networking.k8s.io/gateway-name=nginx \
    --timeout=120s
  ok "gateway-api listo"

  info "2/7 — KEDA"
  helmfile --file helmfile.d/02-keda.yaml -e "${ENVIRONMENT}" apply --suppress-diff
  ok "KEDA instalado"

  info "3/7 — Database operators"
  helmfile --file helmfile.d/03-database-operators.yaml -e "${ENVIRONMENT}" apply --suppress-diff
  ok "Database operators instalados"

  info "4/7 — Stack LGTM (Loki · Grafana · Tempo · Mimir)"
  helmfile --file helmfile.d/04-observability.yaml -e "${ENVIRONMENT}" apply --suppress-diff

  info "Esperando que Grafana esté listo (puede tardar ~2 min)..."
  kubectl wait --namespace grafana \
    --for=condition=ready pod \
    --selector=app.kubernetes.io/name=grafana \
    --timeout=300s
  ok "Stack LGTM listo"

  info "5/7 — Ganesha NFS"
  helmfile --file helmfile.d/05-ganesha-nfs.yaml -e "${ENVIRONMENT}" apply --suppress-diff

  info "Esperando que Ganesha NFS esté listo (puede tardar ~2 min)..."
  kubectl wait --namespace ganesha-nfs \
    --for=condition=ready pod \
    --selector=app=nfs-server-provisioner \
    --timeout=300s
  ok "Ganesha NFS listo"

  info "6/7 — Aplicaciones (Redmine - Wordpress - Wagtail)"
  helmfile --file helmfile.d/06-applications.yaml -e "${ENVIRONMENT}" apply --suppress-diff

  info "7/7 — Locust"
  helmfile --file helmfile.d/07-load-test.yaml -e "${ENVIRONMENT}" apply --suppress-diff
}

# ---------------------------------------------------------------------------
# Comandos principales
# ---------------------------------------------------------------------------

cmd_up() {
  check_requirements
  create_cluster
  install_infra

  echo ""
  echo -e "${GREEN}${BOLD}Ambiente listo.${NC}"
  echo ""
  echo -e "  ${BOLD}Grafana${NC}   →  http://grafana.localhost"
  echo -e "  ${BOLD}Locust${NC}    →  http://locust.localhost"
  echo ""
  echo "  Para desplegar las apps demo consultá el README."
  echo "  Para ver el estado: $(basename "$0") status"
  echo ""
}

cmd_down() {
  header "Eliminando cluster '${CLUSTER_NAME}'"
  if cluster_exists; then
    kind delete cluster --name "$CLUSTER_NAME"
    ok "Cluster eliminado."
  else
    warn "El cluster '${CLUSTER_NAME}' no existe."
  fi
}

cmd_status() {
  if ! cluster_exists; then
    warn "El cluster '${CLUSTER_NAME}' no existe. Ejecutá: $(basename "$0") up"
    exit 1
  fi

  header "Nodos"
  kubectl get nodes -o wide

  header "Pods por namespace"
  kubectl get pods -A --sort-by=.metadata.namespace

  header "Ingresses"
  kubectl get ingress -A 2>/dev/null || true
}

# ---------------------------------------------------------------------------
# Entrypoint
# ---------------------------------------------------------------------------

case "${1:-}" in
  up)            cmd_up     ;;
  down)          cmd_down   ;;
  status)        cmd_status ;;
  -h|--help|"") usage       ;;
  *)             die "Comando desconocido: '$1'. Usá --help para ver las opciones." ;;
esac
