{
    "name": "opentelemetry/wordpress-demo",
    "description": "Demo de instrumentación de opentelemetry para la tesis Observabilidad, una base para aplicaciones resilientes",
    "type": "project",
    "minimum-stability": "beta",
    "require": {
        "open-telemetry/opentelemetry-auto-wordpress": "^0.0.15",
        "open-telemetry/sdk": "^1.0",
        "open-telemetry/exporter-otlp": "^1.0",
        "php-http/guzzle7-adapter": "^1.0"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}